# MongoDB Atlas connection string (replace with your actual connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/multiartwork?retryWrites=true&w=majority

# JWT Secret for authentication (change this to a strong random string in production)
JWT_SECRET=replace_this_with_a_strong_secret

# API Base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Cloudinary credentials (get these from cloudinary.com after creating an account)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
